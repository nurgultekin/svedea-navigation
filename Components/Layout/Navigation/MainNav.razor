@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div class="main-nav-wrapper" @onkeydown="HandleKeyDown">
    <DesktopNav
        PrimaryNav="_primaryNav"
        InsuranceOpen="_insuranceOpen"
        OnInsuranceToggle="ToggleInsurance"
        OnInsuranceClose="CloseInsurance"
        SearchOpen="_searchOpen"
        OnSearchToggle="ToggleSearch" />

    <MobileNav
        PrimaryNav="_primaryNav"
        IsOpen="_mobileOpen"
        OnToggle="ToggleMobile"
        OnClose="CloseMobile" />
</div>

@if (_insuranceOpen)
{
    <div class="nav-backdrop" @onclick="CloseInsurance" aria-hidden="true"></div>
    <InsuranceDropdown
        Categories="_insuranceCategories"
        InsuranceUrl="@_insuranceItem?.Url"
        IsOpen="_insuranceOpen"
        OnClose="CloseInsurance" />
}

@if (_searchOpen)
{
    <div class="nav-backdrop" @onclick="CloseSearch" aria-hidden="true"></div>
}
<SearchPanel IsOpen="_searchOpen"
             OnClose="CloseSearch"
             NavTree="_primaryNav" />

@code {
    private bool _insuranceOpen = false;
    private bool _mobileOpen = false;
    private bool _searchOpen = false;
    private List<NavItem> _primaryNav = NavMenuData.GetPrimaryNav();
    private NavItem? _insuranceItem;
    private List<NavItem> _insuranceCategories = new();
    private DotNetObjectReference<MainNav>? _dotNetRef;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        _insuranceItem = _primaryNav.FirstOrDefault(x => x.Children != null);
        _insuranceCategories = _insuranceItem?.Children ?? new();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("navBreakpoint.watch", _dotNetRef, "(min-width: 62em)");
        }
    }

    [JSInvokable]
    public void OnEnterDesktop()
    {
        _mobileOpen = false;
        _insuranceOpen = false;
        _searchOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _mobileOpen = false;
        _insuranceOpen = false;
        _searchOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleInsurance()
    {
        _insuranceOpen = !_insuranceOpen;
        if (_insuranceOpen) _searchOpen = false;
    }
    private void CloseInsurance() => _insuranceOpen = false;
    private void ToggleMobile() => _mobileOpen = !_mobileOpen;
    private void CloseMobile() => _mobileOpen = false;
    private void ToggleSearch()
    {
        _searchOpen = !_searchOpen;
        if (_searchOpen) _insuranceOpen = false;
    }
    private void CloseSearch() => _searchOpen = false;

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            _insuranceOpen = false;
            _mobileOpen = false;
            _searchOpen = false;
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _dotNetRef?.Dispose();
    }
}
