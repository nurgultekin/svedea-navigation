@inject NavigationManager Nav

<div class="mobile-cat">
    <button class="mobile-cat__toggle"
            aria-expanded="@IsOpen.ToString().ToLower()"
            aria-controls="mobile-cat-@_id"
            @onclick="HandleToggle">
        <span class="mobile-cat__name">@Category.Name</span>
        <svg class="mobile-cat__chevron @(IsOpen ? "is-open" : "")"
             aria-hidden="true" width="16" height="16"
             viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6"/>
        </svg>
    </button>

    <ul id="mobile-cat-@_id"
        class="mobile-cat__links @(IsOpen ? "is-open" : "")"
        role="list">
        @foreach (var link in Category.Links)
        {
            <li>
                <a href="@link.Url"
                   class="mobile-cat__link @(IsCurrentPage(link.Url) ? "is-active" : "")">
                    @link.Label
                </a>
            </li>
        }
    </ul>
</div>

@code {
    [Parameter] public NavCategory Category { get; set; } = null!;
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<string> OnToggle { get; set; }

    private string _id => Category.Name.Replace(" ", "-").ToLowerInvariant();

    private void HandleToggle() => OnToggle.InvokeAsync(Category.Name);

    private bool IsCurrentPage(string url) =>
        Nav.Uri.EndsWith(url, StringComparison.OrdinalIgnoreCase);
}
