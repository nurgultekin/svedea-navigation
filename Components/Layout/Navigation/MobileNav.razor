@inject NavigationManager Nav
@inject IJSRuntime JS

<!-- Mobile header bar (always visible on mobile) -->
<div class="mobile-nav">
    <div class="mobile-nav__bar">
        <div class="mobile-nav__bar-left">
            <a href="#" class="btn btn--icon" aria-label="Logga in"
               aria-hidden="@(IsOpen ? "true" : null)" tabindex="@(IsOpen ? -1 : 0)">
                <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </a>
        </div>

        <a href="/" class="nav-logo-link" aria-label="Svedea – gå till startsidan">
            <img src="/media/svedea_logo_white.png" alt="Svedea" class="nav-logo" />
        </a>

        <button id="mobile-hamburger" class="btn btn--icon" aria-label="@(IsOpen ? "Stäng meny" : "Öppna meny")"
                aria-expanded="@IsOpen.ToString().ToLower()" aria-controls="mobile-overlay"
                aria-hidden="@(IsOpen ? "true" : null)" tabindex="@(IsOpen ? -1 : 0)"
                @onclick="OnToggle">
            @if (IsOpen)
            {
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6L6 18M6 6l12 12" />
                </svg>
            }
            else
            {
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 30 30" fill="none"
                     xmlns="http://www.w3.org/2000/svg">
                    <path stroke="currentColor" stroke-linecap="round" stroke-miterlimit="10" stroke-width="2"
                          d="M4 7h22M4 15h22M4 23h22" />
                </svg>
            }
        </button>
    </div>

    <!-- Overlay panel -->
    <div id="mobile-overlay" class="mobile-nav__overlay @(IsOpen ? "is-open" : "")" role="dialog" aria-modal="true"
         aria-label="Navigeringsmeny" @onkeydown="HandleKeyDown" @onclick="HandleOverlayClick">

        <!-- Overlay header -->
        <div class="mobile-nav__overlay-header">
            <div class="mobile-nav__overlay-icons">
                <a href="#" class="btn btn--icon" aria-label="Logga in">
                    <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </a>
            </div>
            <a href="/" class="nav-logo-link" aria-label="Svedea – gå till startsidan">
                <img src="/media/svedea_logo_white.png" alt="Svedea" class="nav-logo" />
            </a>
            <button id="mobile-overlay-close" class="btn btn--icon" aria-label="Stäng meny" @onclick="OnClose">
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6L6 18M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Search -->
        <div class="mobile-nav__search" @onclick:stopPropagation="true">
            <label for="mobile-search" class="sr-only">Sök</label>
            <div class="mobile-nav__search-wrap @(ShowResults ? "has-results" : "")">
                <div class="mobile-nav__search-row">
                    <svg aria-hidden="true" class="mobile-nav__search-icon" width="18" height="18" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.35-4.35" />
                    </svg>
                    <input id="mobile-search" type="search" placeholder="Sök på svedea..."
                           class="mobile-nav__search-input"
                           @oninput="HandleSearchInput" @onfocus="OnSearchFocus"
                           @onblur="OnSearchBlur" />
                </div>
                <p class="sr-only" role="status" aria-live="polite" aria-atomic="true">@_statusMessage</p>
                <ul class="mobile-nav__search-results @(ShowResults ? "is-open" : "")" role="list"
                    aria-label="Sökresultat">
                    @foreach (var r in SearchResults)
                    {
                        <li>
                            <a href="@r.Url" class="mobile-nav__search-result-item focus-ring"
                               @onclick="OnClose">
                                @r.Label
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Nav content (fully data-driven) -->
        <nav class="mobile-nav__content" aria-label="Mobil navigation">
            @foreach (var item in PrimaryNav)
            {
                if (item.Children != null)
                {
                    <div class="mobile-nav__dropdown @(_insuranceOpen ? "is-open" : "")">
                        <button class="nav-link mobile-nav__top-link mobile-nav__dropdown-toggle focus-ring"
                                aria-expanded="@_insuranceOpen.ToString().ToLower()" aria-controls="mobile-insurance-panel"
                                @onclick="ToggleInsurance">
                            <span class="btn-label btn-label--xl">@item.Label</span>
                            <svg class="chevron @(_insuranceOpen ? "is-open" : "")" aria-hidden="true" width="16" height="16"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round">
                                <path d="M6 9l6 6 6-6" />
                            </svg>
                        </button>
                        <div id="mobile-insurance-panel"
                             class="mobile-nav__dropdown-panel nav-stagger @(_insuranceOpen ? "is-open" : "")">
                            @foreach (var category in item.Children)
                            {
                                <MobileCategoryItem Category="category" IsOpen="_openCategory == category.Label"
                                                    OnToggle="ToggleCategory" />
                            }
                            @if (item.Url != null)
                            {
                                <a href="@item.Url" class="btn btn--tertiary btn--tertiary--white focus-ring" @onclick="OnClose">
                                    <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M5 12h14M12 5l7 7-7 7" />
                                    </svg>
                                    Se alla @item.Label.ToLower()
                                </a>
                            }
                        </div>
                    </div>
                    <div class="mobile-nav__divider" role="separator"></div>
                }
                else
                {
                    <a href="@item.Url"
                       class="nav-link mobile-nav__top-link focus-ring @(IsActive(item.Url!) ? "is-active" : "")"
                       aria-current="@(IsActive(item.Url!) ? "page" : null)" @onclick="OnClose">
                        <span class="btn-label btn-label--xl">@item.Label</span>
                    </a>
                }
            }
        </nav>

        <!-- Bottom CTAs -->
        <div class="mobile-nav__footer">
            <a href="#" class="btn btn--primary btn--lg">
                <svg aria-hidden="true" width="18" height="18"
                     viewBox="0 0 24 24" fill="none"
                     style="visibility: hidden;">
                    <circle cx="12" cy="12" r="1"/>
                </svg>
                Anmäl skada
            </a>
            <a href="#"
               class="btn btn--tertiary btn--tertiary--light btn--tertiary--lg focus-ring">
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 9.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6.29 6.29l1.06-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
                Kontakt
            </a>
            <a href="#"
               class="btn btn--tertiary btn--tertiary--light btn--tertiary--lg focus-ring">
                <svg aria-hidden="true" width="18" height="18"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round"
                     stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
                Logga in
            </a>
        </div>
    </div>

    <!-- Backdrop (closes overlay when tapping outside on tablet) -->
    @if (IsOpen)
    {
        <div class="mobile-nav__backdrop" @onclick="OnClose" aria-hidden="true"></div>
    }
</div>

@code {
    [Parameter] public List<NavItem> PrimaryNav { get; set; } = new();
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnToggle { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string? _openCategory;
    private bool _prevIsOpen;
    private bool _insuranceOpen;
    private string _searchQuery = "";
    private bool _searchFocused;
    private string _statusMessage = "";

    private bool ShowResults => _searchFocused && SearchResults.Any();

    private IEnumerable<NavItem> SearchResults =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? Enumerable.Empty<NavItem>()
            : FlattenNav(PrimaryNav)
                .Where(x => x.Url != null &&
                            x.Label.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
                .Take(7);

    private IEnumerable<NavItem> FlattenNav(IEnumerable<NavItem> items) =>
        items.SelectMany(x => x.Children != null
            ? FlattenNav(x.Children).Prepend(x)
            : new[] { x });

    private bool IsActive(string path) =>
        Nav.Uri.Contains(path, StringComparison.OrdinalIgnoreCase);

    protected override void OnParametersSet()
    {
        if (_prevIsOpen && !IsOpen)
        {
            _openCategory = null;
            _insuranceOpen = false;
            _searchQuery = "";
            _searchFocused = false;
            _statusMessage = "";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen && !_prevIsOpen)
        {
            await JS.InvokeVoidAsync("trapFocus", "mobile-overlay");
            await JS.InvokeVoidAsync("focusElement", "mobile-overlay-close");
        }
        else if (!IsOpen && _prevIsOpen)
        {
            await JS.InvokeVoidAsync("focusElement", "mobile-hamburger");
        }
        _prevIsOpen = IsOpen;
    }

    private void OnSearchFocus() => _searchFocused = true;

    private async Task OnSearchBlur(FocusEventArgs _)
    {
        await Task.Delay(150);
        _searchFocused = false;
    }

    private void HandleSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? string.Empty;
        var results = SearchResults.ToList();
        _statusMessage = results.Any()
            ? $"{results.Count} resultat"
            : (_searchQuery.Length > 1 ? "Inga resultat" : "");
    }

    // clear _openCategory when dropdown is closed; reset state
    private void ToggleInsurance()
    {
        _insuranceOpen = !_insuranceOpen;
        if (!_insuranceOpen)
            _openCategory = null;
    }

    private void ToggleCategory(string name) =>
        _openCategory = _openCategory == name ? null : name;

    private void HandleOverlayClick()
    {
        _searchFocused = false;
        _searchQuery = "";
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            OnClose.InvokeAsync();
    }
}
